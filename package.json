{
  "name": "t-music-rpc",
  "version": "1.1.0",
  "description": "T-Music RPC Client",
  "main": "dist/index.js",
  "bin": "dist/index.js",
  "pkg": {
    "assets": [
      "assets/**/*",
      "settings.default.json",
      "node_modules/systray2/traybin/tray_windows_release.exe",
      "node_modules/systray2/traybin/tray_linux_release"
    ],
    "targets": [
      "node18-win-x64",
      "node18-linux-x64"
    ],
    "icon": "assets/icon.ico",
    "outputPath": "dist"
  },
  "scripts": {
    "start": "node dist/index.js",
    "build": "tsc",
    "package": "npm run build && pkg . --compress Brotli --output dist/t-music-bot-rpc",
    "dev": "ts-node index.ts",
    "legacy": "node index.js"
  },
  "dependencies": {
    "@t_bot-team/discord-rpc": "^4.0.5",
    "fft-js": "^0.0.12",
    "systray2": "^2.1.4",
    "ws": "^8.19.0"
  },
  "devDependencies": {
    "@types/node": "^18.11.18",
    "@types/ws": "^8.5.4",
    "pkg": "^5.8.1",
    "rcedit": "^5.0.2",
    "ts-node": "^10.9.1",
    "typescript": "^4.9.4"
  }
}
