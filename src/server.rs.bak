use crate::{info, AppState, OverlayConfig, Settings, TrackUpdate};
use axum::{
    extract::{
        ws::{Message, WebSocket, WebSocketUpgrade},
        Query, State,
    },
    response::{Html, IntoResponse},
    routing::get,
    Json, Router,
};
use std::collections::HashMap;
use std::sync::Arc;
use tokio::sync::broadcast;

pub struct ServerHandle {
    pub tx: broadcast::Sender<String>,
}

pub async fn start_server(state: AppState) {
    let (port, tx) = {
        let s = state.read().await;
        (
            s.settings.as_ref().unwrap().overlay.port,
            s.overlay_tx.clone(),
        )
    };

    let server_handle = Arc::new(ServerHandle { tx });

    let app = Router::new()
        .route("/", get(overlay_handler))
        .route("/ws", get(ws_handler))
        .route("/settings", get(settings_gui_handler))
        .route(
            "/api/settings",
            get(get_settings_handler).post(update_settings_handler),
        )
        .route("/assets/:path", get(asset_handler))
        .with_state((state.clone(), server_handle));

    let addr = format!("127.0.0.1:{}", port);
    match tokio::net::TcpListener::bind(&addr).await {
        Ok(listener) => {
            info!("[Server] Overlay active on http://{}", addr);
            axum::serve(listener, app).await.unwrap();
        }
        Err(e) => {
            info!(
                "[Server] CRITICAL: Permission Denied on port {} ({}).",
                port, e
            );
        }
    }
}

async fn asset_handler(
    axum::extract::Path(path): axum::extract::Path<String>,
) -> impl IntoResponse {
    let clean_path = path.trim_start_matches('/');
    let mime = match clean_path.split('.').last() {
        Some("png") => "image/png",
        Some("ico") => "image/x-icon",
        _ => "application/octet-stream",
    };

    let content: Option<&'static [u8]> = match clean_path {
        "avatar.png" => Some(include_bytes!("../assets/avatar.png")),
        "music.png" => Some(include_bytes!("../assets/music.png")),
        "icon.png" => Some(include_bytes!("../assets/icon.png")),
        "icon.ico" => Some(include_bytes!("../assets/icon.ico")),
        _ => None,
    };

    if let Some(c) = content {
        ([(axum::http::header::CONTENT_TYPE, mime)], c).into_response()
    } else {
        (axum::http::StatusCode::NOT_FOUND, "Not Found").into_response()
    }
}

async fn overlay_handler(
    State((state, _)): State<(AppState, Arc<ServerHandle>)>,
    Query(params): Query<HashMap<String, String>>,
) -> impl IntoResponse {
    let s = state.read().await;
    let settings = s.settings.as_ref().unwrap();
    let layout_override = params.get("layout").cloned();
    Html(get_html(
        &settings.overlay,
        s.last_track.as_ref(),
        layout_override,
    ))
}

async fn settings_gui_handler() -> impl IntoResponse {
    Html(include_str!("gui.html"))
}
async fn get_settings_handler(
    State((state, _)): State<(AppState, Arc<ServerHandle>)>,
) -> impl IntoResponse {
    Json(state.read().await.settings.clone())
}

async fn update_settings_handler(
    State((state, handle)): State<(AppState, Arc<ServerHandle>)>,
    Json(new_settings): Json<Settings>,
) -> impl IntoResponse {
    let mut s = state.write().await;
    s.settings = Some(new_settings.clone());
    crate::utils::save_settings(&new_settings);
    info!("[Server] Settings updated. Broadcasting live reload...");
    let _ = handle
        .tx
        .send(serde_json::json!({ "type": "settings_update" }).to_string());
    serde_json::json!({ "status": "success" })
        .to_string()
        .into_response()
}

async fn ws_handler(
    ws: WebSocketUpgrade,
    State((state, handle)): State<(AppState, Arc<ServerHandle>)>,
) -> impl IntoResponse {
    ws.on_upgrade(move |socket| handle_socket(socket, state, handle))
}

async fn handle_socket(mut socket: WebSocket, state: AppState, handle: Arc<ServerHandle>) {
    let mut rx = handle.tx.subscribe();
    {
        let s = state.read().await;
        let track = s.last_track.clone().unwrap_or_default();
        let _ = socket
            .send(Message::Text(
                serde_json::json!({ "type": "track_update", "data": track })
                    .to_string()
                    .into(),
            ))
            .await;
    }
    loop {
        tokio::select! {
            res = rx.recv() => {
                match res {
                    Ok(msg) => { if socket.send(Message::Text(msg.into())).await.is_err() { break; } }
                    Err(tokio::sync::broadcast::error::RecvError::Lagged(_)) => continue,
                    Err(tokio::sync::broadcast::error::RecvError::Closed) => break,
                }
            }
            msg = socket.recv() => { if msg.is_none() { break; } }
        }
    }
}

pub fn get_html(
    overlay: &OverlayConfig,
    last_track: Option<&TrackUpdate>,
    layout_override: Option<String>,
) -> String {
    let viz = &overlay.visualizer;
    let track = last_track.cloned().unwrap_or_default();
    let track_json = serde_json::to_string(&track).unwrap();

    let layout_mode = layout_override.unwrap_or(overlay.layout.clone());

    // Dynamically adjust the canvas wrapper based on the layout string
    let wrapper_w = match layout_mode.as_str() {
        "compact-bar" => 800,
        "compact-minimal" => 600,
        _ => 1360, // Full Spread
    };
    let wrapper_h = match layout_mode.as_str() {
        "compact-bar" => 200,
        "compact-minimal" => 160,
        _ => 440, // Full Spread
    };

    format!(
        r##"<!DOCTYPE html><html><head><style>
        html, body {{ background: transparent !important; margin: 0; padding: 0; overflow: hidden; width: {wrapper_w}px; height: {wrapper_h}px; color: {text_color}; }}
        body {{ font-family: 'Segoe UI', sans-serif; }}
        
        #scale-wrapper {{ width: {wrapper_w}px; height: {wrapper_h}px; position: relative; }}
        
        /* THE SQUARE BORDER FIX: bg-blur is now safely inside #widget so it gets clipped */
        #widget {{ display: flex; align-items: center; padding: 60px; border-radius: 48px; width: 100%; height: 100%; box-sizing: border-box; position: relative; gap: 40px; overflow: hidden; border: 2px solid {border_color}; transition: all 0.3s ease; }}
        
        #bg-blur {{ position: absolute; inset: -20px; z-index: -1; filter: blur(60px); opacity: 0; background-size: cover; background-position: center; transition: opacity 0.5s ease, background-image 0.5s ease; }}
        #bg-blur.visible {{ opacity: {thumb_opacity}; }}
        #widget::before {{ content: ''; position: absolute; inset: 0; background: {bg_color} !important; z-index: -2; }}
        
        #img-container {{ position: relative; width: 320px; height: 320px; flex-shrink: 0; transition: all 0.3s ease; }}
        
        /* THE AVATAR FIX: Nuked the white background and border entirely */
        #avatar-img {{ position: absolute; top: -10px; left: -10px; width: 110px; height: 110px; z-index: 110; border-radius: 50%; object-fit: cover; box-shadow: 0 4px 15px rgba(0,0,0,0.5); background: transparent; border: none; }}
        #track-img-wrapper {{ width: 100%; height: 100%; border-radius: 32px; overflow: hidden; position: relative; z-index: 100; box-shadow: 0 10px 30px rgba(0,0,0,0.6); }}
        #track-img {{ width: 100%; height: 100%; object-fit: cover; }}
        
        /* THE DESIGN FIX: Stacked tightly in the center, no floating elements */
        #info {{ display: flex; flex-direction: column; justify-content: center; height: 320px; flex-grow: 1; min-width: 0; transition: all 0.3s ease; }}
        #info.centered {{ align-items: center; text-align: center; }}
        
        #text-wrapper {{ display: flex; flex-direction: column; gap: 4px; overflow: hidden; width: 100%; }}
        #title {{ font-weight: bold; font-size: 3.8em; margin: 0; white-space: nowrap; text-overflow: ellipsis; overflow: hidden; line-height: 1.2; text-shadow: 0 4px 12px rgba(0,0,0,0.9); transition: color 0.3s ease; }}
        #artist {{ font-size: 2.8em; color: rgba(255,255,255,0.7); margin: 0; white-space: nowrap; text-overflow: ellipsis; overflow: hidden; text-shadow: 0 2px 8px rgba(0,0,0,0.8); }}
        
        #progress-area {{ display: none; align-items: center; width: 100%; gap: 15px; margin-top: 15px; }}
        #progress-area.visible {{ display: flex; }}
        #progress-container {{ flex-grow: 1; height: 14px; background: {element_color}; border-radius: 7px; overflow: hidden; box-shadow: inset 0 2px 5px rgba(0,0,0,0.5); }}
        #progress-bar {{ width: 0%; height: 100%; border-radius: 6px; transition: width 0.1s linear, background 0.3s ease; }}
        #time-text {{ font-size: 2.2em; font-weight: 500; font-variant-numeric: tabular-nums; text-shadow: 0 2px 5px rgba(0,0,0,0.8); white-space: nowrap; }}
        
        #live-indicator {{ display: none; align-items: center; justify-content: flex-end; gap: 12px; color: #ff4444; font-weight: bold; font-size: 2.2em; text-transform: uppercase; letter-spacing: 2px; text-shadow: 0 0 15px rgba(255,68,68,0.4); margin-top: 10px; width: 100%; }}
        #live-indicator.visible {{ display: flex; }}
        #live-dot {{ width: 18px; height: 18px; background-color: #ff4444; border-radius: 50%; box-shadow: 0 0 10px #ff4444; animation: pulse 1.5s infinite; }}
        @keyframes pulse {{ 0% {{ transform: scale(1); opacity: 1; }} 50% {{ transform: scale(1.3); opacity: 0.5; }} 100% {{ transform: scale(1); opacity: 1; }} }}

        #viz-canvas {{ display: block; margin-top: 25px; }}
        #fps-text {{ position: absolute; bottom: 10px; right: 20px; font-size: 1.2em; color: rgba(255,255,255,0.3); font-family: monospace; display: {debug_display}; }}
        
        /* RESTING MODES */
        #widget.idle #img-container, #widget.offline #img-container {{ display: none !important; }}
        #widget.idle #info, #widget.offline #info {{ justify-content: center; text-align: center; align-items: center; }}
        #widget.idle #progress-area, #widget.idle #viz-canvas, #widget.idle #fps-text,
        #widget.offline #progress-area, #widget.offline #viz-canvas, #widget.offline #fps-text {{ display: none !important; opacity: 0 !important; visibility: hidden !important; }}

        /* --- COMPACT MODES --- */
        #widget.compact-bar {{ padding: 20px; border-radius: 24px; gap: 20px; height: 200px; }}
        #widget.compact-bar #img-container {{ width: 160px; height: 160px; }}
        #widget.compact-bar #avatar-img {{ width: 50px; height: 50px; top: -8px; left: -8px; }}
        #widget.compact-bar #info {{ height: 160px; justify-content: center; }}
        #widget.compact-bar #title {{ font-size: 2.8em; }}
        #widget.compact-bar #artist {{ font-size: 2.0em; }}
        #widget.compact-bar #progress-area {{ margin-top: 15px; }}
        #widget.compact-bar #progress-container {{ height: 16px; }}
        #widget.compact-bar #time-text {{ font-size: 1.8em; }}
        #widget.compact-bar #viz-canvas {{ display: none !important; }} 

        #widget.compact-minimal {{ padding: 20px; border-radius: 24px; gap: 20px; height: 160px; }}
        #widget.compact-minimal #img-container {{ width: 120px; height: 120px; }}
        #widget.compact-minimal #avatar-img {{ width: 45px; height: 45px; top: -5px; left: -5px; }}
        #widget.compact-minimal #info {{ height: 120px; justify-content: center; }}
        #widget.compact-minimal #title {{ font-size: 2.4em; }}
        #widget.compact-minimal #artist {{ font-size: 1.6em; }}
        #widget.compact-minimal #progress-area, #widget.compact-minimal #viz-canvas {{ display: none !important; }}

    </style></head><body><div id="scale-wrapper">
        <div id="widget" class="offline {layout_class}">
            <div id="bg-blur"></div>
            
            <div id="img-container">
                <img id="avatar-img" src="/assets/avatar.png" />
                <div id="track-img-wrapper"><img id="track-img" src="/assets/music.png" crossorigin="anonymous" /></div>
            </div>
            <div id="info" class="{center_class}">
                <div id="text-wrapper"><div id="title">Server Offline</div><div id="artist">Waiting for Rust...</div></div>
                <div id="live-indicator"><div id="live-dot"></div><span>LIVE</span></div>
                <div id="progress-area">
                    <div id="progress-container"><div id="progress-bar"></div></div>
                    <div id="time-text">0:00 / 0:00</div>
                </div>
                <canvas id="viz-canvas"></canvas>
            </div>
            <div id="fps-text">0 FPS</div>
        </div>
    </div><script>
        let track = {track_json}, bins = new Uint8Array({bars}).fill(0), isOffline = true;
        const widget = document.getElementById("widget"), bgBlur = document.getElementById("bg-blur");
        const canvas = document.getElementById("viz-canvas"), ctx = canvas.getContext("2d", {{ alpha: true }});
        
        const randomHex = () => "#" + Math.floor(Math.random()*16777215).toString(16).padStart(6, '0');
        const isStatic = {is_static}, isGlobalSync = {global_sync}, mode = "{viz_mode}";
        let cTop = {is_random} ? randomHex() : "{v_top}", cBot = {is_random} ? randomHex() : "{v_bot}";
        if (isStatic) cBot = cTop;

        const progBar = document.getElementById("progress-bar"), timeText = document.getElementById("time-text");
        const liveIndicator = document.getElementById("live-indicator");
        const trackImg = document.getElementById('track-img');
        
        trackImg.onload = () => {{
            if (isGlobalSync && !isOffline && trackImg.src.includes("http")) {{
                try {{
                    const temp = document.createElement('canvas');
                    temp.width = 1; temp.height = 1;
                    const tCtx = temp.getContext('2d');
                    tCtx.drawImage(trackImg, 0, 0, 1, 1);
                    const [r, g, b] = tCtx.getImageData(0, 0, 1, 1).data;
                    const domColor = `rgb(${{r}},${{g}},${{b}})`;
                    
                    cTop = domColor; cBot = domColor;
                    document.getElementById('title').style.color = domColor;
                }} catch(e) {{ console.log("CORS blocked sync"); }}
            }} else if (!isGlobalSync) {{
                document.getElementById('title').style.color = "{text_color}";
            }}
            progBar.style.background = isStatic ? cTop : `linear-gradient(90deg, ${{cBot}}, ${{cTop}})`;
            progBar.style.boxShadow = `0 0 10px ${{cTop}}80`;
        }};

        function updateUI() {{
            const isIdle = !track || !track.details || track.details === "Disconnected" || track.details === "Resting..." || track.details === "Not Playing";
            const isPaused = !!track.paused;
            widget.className = (isOffline ? "offline" : (isIdle ? "idle" : (isPaused ? "paused playing" : "playing"))) + " {layout_class}";
            
            document.getElementById("title").innerText = isOffline ? "Server Offline" : (track.details || "Resting...");
            document.getElementById("artist").innerText = isOffline ? "Waiting for connection..." : (track.state || "Browsing for music");
            
            const thumb = (isIdle || isOffline) ? "/assets/music.png" : (track.thumbnail || "/assets/music.png");
            trackImg.src = thumb; 
            
            if({show_bg_blur}) {{
                bgBlur.style.backgroundImage = `url("${{thumb}}")`;
                bgBlur.classList.add("visible");
            }} else {{ bgBlur.classList.remove("visible"); }}
        }}

        function connect() {{
            const socket = new WebSocket("ws://" + location.host + "/ws");
            socket.onopen = () => {{ isOffline = false; updateUI(); }};
            socket.onmessage = (e) => {{
                const m = JSON.parse(e.data);
                if (m.type === "track_update") {{ track = m.data; updateUI(); }}
                if (m.type === "fft_data") {{ bins.set(m.bins); }}
                if (m.type === "settings_update") {{ location.reload(); }}
            }};
            socket.onclose = () => {{ isOffline = true; updateUI(); setTimeout(connect, 2000); }};
        }}

        const BARS = {bars};
        const heights = new Float32Array(BARS).fill(0);
        
        const DPR = Math.max(window.devicePixelRatio || 1, 2); 
        const baseW = 880;
        const baseH = 100;
        
        canvas.style.width = baseW + "px";
        canvas.style.height = baseH + "px";
        canvas.width = baseW * DPR;
        canvas.height = baseH * DPR;
        
        const totalUnits = ({bar_w} * BARS) + ({bar_g} * (BARS - 1));
        const barW = (baseW / totalUnits) * {bar_w}, gap = (baseW / totalUnits) * {bar_g};

        let lastFrame = performance.now(), frameCount = 0, lastFpsUpdate = lastFrame;
        const frameTarget = 1000 / {fps};

        function draw(now) {{
            requestAnimationFrame(draw);
            if (isOffline || now - lastFrame < frameTarget - 0.5) return;
            lastFrame = now;

            const isIdle = widget.classList.contains("idle"), isPaused = widget.classList.contains("paused");
            const hasEnd = !!track.endTimestamp;
            const hasStart = !!track.startTimestamp;
            
            if (!isIdle && !isOffline) {{
                const start = (track.start_timestamp || 0) * (track.start_timestamp < 1e12 ? 1000 : 1);
                const end = (track.end_timestamp || 0) * (track.end_timestamp < 1e12 ? 1000 : 1);
                
                const tNow = Date.now();
                const total = end > start ? end - start : 0; 
                const current = isPaused ? (track.position || 0) : Math.max(0, Math.min(total, tNow - start));
                
                const isLive = !end && start && !isPaused;
                const shouldShowProgress = end > 0 && !isPaused && total > 0;
                
                liveIndicator.classList.toggle("visible", isLive);
                document.getElementById("progress-area").classList.toggle("visible", shouldShowProgress);

                if (shouldShowProgress) {{
                    progBar.style.width = ((current / total) * 100) + "%";
                    const fmt = (ms) => {{ 
                        let s=Math.floor(Math.max(0, ms)/1000); 
                        return Math.floor(s/60)+":"+(s%60).toString().padStart(2,"0"); 
                    }};
                    timeText.innerText = fmt(current) + " / " + fmt(total);
                }}
            }} else {{
                document.getElementById("progress-area").classList.remove("visible");
                liveIndicator.classList.remove("visible");
            }}

            ctx.setTransform(DPR, 0, 0, DPR, 0, 0);
            ctx.clearRect(0, 0, baseW, baseH);
            
            if(isIdle || isPaused || isOffline || !{viz_enabled}) return;

            // PHYSICS ENGINE
            const physicsEnabled = {viz_physics};
            for(let i=0; i<BARS; i++) {{
                let target = (bins[i] / 255) * (baseH - 6);
                
                if (physicsEnabled) {{
                    const l = i > 0 ? (bins[i-1] / 255) * (baseH - 6) : 0;
                    const r = i < BARS - 1 ? (bins[i+1] / 255) * (baseH - 6) : 0;
                    if (l * 0.65 > target) target = l * 0.65;
                    if (r * 0.65 > target) target = r * 0.65;
                }}

                if (target > heights[i]) {{
                    heights[i] = target; 
                }} else {{
                    const diff = heights[i] - target;
                    heights[i] -= (diff * 0.22 > 1) ? diff * 0.22 : 1;
                }}
            }}
            
            const barGrad = ctx.createLinearGradient(0, 0, 0, baseH);
            barGrad.addColorStop(0, cTop); barGrad.addColorStop(1, cBot);
            
            if ({viz_glow}) {{
                ctx.shadowBlur = 15;
                ctx.shadowColor = cTop;
            }}

            ctx.fillStyle = barGrad;
            ctx.strokeStyle = barGrad;
            
            if (mode === "wave") {{
                ctx.lineWidth = 4;
                ctx.lineJoin = "round";
                ctx.beginPath();
                const pts = [];
                for(let i=0; i<BARS; i++) pts.push({{x: i * (barW + gap) + barW/2, y: baseH - Math.max(4, heights[i])}});
                if(pts.length > 0) {{
                    ctx.moveTo(pts[0].x, pts[0].y);
                    for (let i = 0; i < pts.length - 1; i++) {{
                        const xc = (pts[i].x + pts[i + 1].x) / 2;
                        const yc = (pts[i].y + pts[i + 1].y) / 2;
                        ctx.quadraticCurveTo(pts[i].x, pts[i].y, xc, yc);
                    }}
                    ctx.stroke();
                    ctx.lineTo(baseW, baseH); ctx.lineTo(0, baseH);
                    ctx.globalAlpha = 0.2; ctx.fill(); ctx.globalAlpha = 1.0;
                }}
            }} 
            else if (mode === "neon") {{
                ctx.lineWidth = 2;
                for(let i=0; i<BARS; i++) {{
                    const h = Math.max(2, heights[i]);
                    ctx.strokeRect(i*(barW+gap), baseH - h, barW, h);
                }}
            }}
            else if (mode === "led") {{
                const dotH = 6;
                for(let i=0; i<BARS; i++) {{
                    const h = heights[i];
                    for(let y = baseH; y > baseH - h; y -= dotH + 2) {{
                        ctx.fillRect(i*(barW+gap), y - dotH, barW, dotH);
                    }}
                }}
            }}
            else if (mode === "outline") {{
                ctx.lineWidth = 2;
                ctx.beginPath();
                for(let i=0; i<BARS; i++) {{
                    const h = Math.max(2, heights[i]);
                    const x = i*(barW+gap), y = baseH-h;
                    if(i===0) ctx.moveTo(x, y); else ctx.lineTo(x, y);
                    ctx.lineTo(x+barW, y);
                }}
                ctx.stroke();
            }}
            else {{
                const rO = {rounded} ? Math.min(barW / 2, 4) : 0;
                ctx.beginPath();
                for(let i=0; i<BARS; i++) {{
                    const h = Math.max(2, heights[i]);
                    const x = mode === "center" ? (baseW/2) + ((i%2===0 ? i/2 : -(i+1)/2) * (barW+gap)) : i*(barW+gap);
                    const y = mode === "center" ? (baseH/2) - (h/2) : baseH-h;
                    
                    if (rO > 0) ctx.roundRect(x, y, barW, h, [rO, rO, rO, rO]);
                    else ctx.rect(x, y, barW, h);
                }}
                ctx.fill();
            }}
            ctx.shadowBlur = 0; 

            frameCount++;
            if(now - lastFpsUpdate >= 1000) {{
                document.getElementById("fps-text").innerText = frameCount + " FPS";
                frameCount = 0; lastFpsUpdate = now;
            }}
        }} 
        updateUI(); connect(); draw(performance.now());
    </script></body></html>"##,
        wrapper_w = wrapper_w,
        wrapper_h = wrapper_h,
        text_color = overlay.text_color,
        border_color = overlay.border_color,
        element_color = overlay.element_color,
        bg_color = &overlay.background.color,
        thumb_opacity = overlay.thumbnail_opacity,
        bars = viz.bars,
        bar_w = viz.bar_width,
        bar_g = viz.bar_gap,
        viz_enabled = viz.enabled,
        viz_mode = viz.mode,
        is_static = viz.gradient.is_static,
        is_random = viz.gradient.random,
        v_top = viz.gradient.top,
        v_bot = viz.gradient.bottom,
        rounded = viz.rounded,
        fps = viz.fps,
        show_bg_blur = overlay.show_background,
        global_sync = overlay.global_sync,
        center_class = if overlay.center_text { "centered" } else { "" },
        layout_class = layout_mode,
        debug_display = if viz.debug_fps { "block" } else { "none" },
        viz_glow = viz.glow,
        viz_physics = viz.horizontal_smoothing,
        track_json = track_json,
    )
}
